{
    "name": "sontus/laravel-support-chatbot",
    "description": "AI-powered support chatbot package for Laravel using Laravel AI SDK.",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Sontus\\SupportChatbot\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sontus\\SupportChatbot\\ChatbotServiceProvider"
            ],
            "aliases": {
                "Chatbot": "Sontus\\SupportChatbot\\Facades\\Chatbot"
            }
        }
    }
}
